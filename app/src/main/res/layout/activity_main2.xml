<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity2">

    <TextView
        android:id="@+id/tvWorkoutName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:gravity="center"
        android:textSize="20sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- 1つ目のラベル（回数） -->
    <TextView
        android:id="@+id/textView2"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="8dp"
        android:text="@string/kaisuu"
        android:textSize="20sp"
        app:layout_constraintBottom_toBottomOf="@+id/layoutTimes"
        app:layout_constraintEnd_toStartOf="@+id/layoutTimes"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@+id/layoutTimes" />

    <!-- 1つ目のプラスマイナス＋数値（回数用） -->
    <LinearLayout
        android:id="@+id/layoutTimes"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:layout_marginEnd="24dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tvWorkoutName">

        <Button
            android:id="@+id/btnTimesMinus"
            android:layout_width="46dp"
            android:layout_height="46dp"
            android:text="－"
            android:textSize="16sp"
            android:padding="0dp"
            android:backgroundTint="#AA1A73F8" />

        <!-- EditTextはそのまま残して、ボタンからの値反映や直接入力もできるようにします -->
        <EditText
            android:id="@+id/etTimes"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:autofillHints="回数"
            android:background="#00000000"
            android:digits="0123456789"
            android:gravity="center"
            android:hint="@string/time"
            android:inputType="number"
            android:minEms="3"
            android:textSize="20sp"
            tools:ignore="SpeakableTextPresentCheck,TouchTargetSizeCheck" />

        <Button
            android:id="@+id/btnTimesPlus"
            android:layout_width="46dp"
            android:layout_height="46dp"
            android:text="＋"
            android:textSize="16sp"
            android:padding="0dp"
            android:backgroundTint="#AA1A73F8" />
    </LinearLayout>


    <!-- 2つ目のラベル（セット数/秒数） -->
    <TextView
        android:id="@+id/textViewRepsLabel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="8dp"
        android:text="@string/times_by_sets"
        android:textSize="20sp"
        app:layout_constraintBottom_toBottomOf="@+id/layoutReps"
        app:layout_constraintEnd_toStartOf="@+id/layoutReps"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@+id/layoutReps" />

    <!-- 2つ目のプラスマイナス＋数値（セット数/秒数用） -->
    <LinearLayout
        android:id="@+id/layoutReps"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:layout_marginEnd="24dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/layoutTimes">

        <Button
            android:id="@+id/btnRepsMinus"
            android:layout_width="46dp"
            android:layout_height="46dp"
            android:text="－"
            android:textSize="16sp"
            android:padding="0dp"
            android:backgroundTint="#AA1A73F8" />

        <EditText
            android:id="@+id/etReps"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:autofillHints="秒数"
            android:background="#00000000"
            android:digits="0123456789"
            android:gravity="center"
            android:hint="@string/ref_hint_times"
            android:inputType="number"
            android:minEms="3"
            android:textSize="20sp"
            tools:ignore="SpeakableTextPresentCheck,TouchTargetSizeCheck" />

        <Button
            android:id="@+id/btnRepsPlus"
            android:layout_width="46dp"
            android:layout_height="46dp"
            android:text="＋"
            android:textSize="16sp"
            android:padding="0dp"
            android:backgroundTint="#AA1A73F8" />
    </LinearLayout>


    <Button
        android:id="@+id/btnSave"
        android:layout_width="200dp"
        android:layout_height="70dp"
        android:layout_marginTop="32dp"
        android:background="@drawable/btn_back_selector"
        android:importantForAccessibility="no"
        android:minWidth="0dp"
        android:minHeight="0dp"
        android:padding="0dp"
        android:text="Change and return"
        android:textColor="#FFFFFF"
        android:textSize="20sp"
        android:textStyle="bold|italic"
        app:backgroundTint="@null"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/layoutReps"
        tools:ignore="TouchTargetSizeCheck,SpeakableTextPresentCheck" />

    <TextView
        android:id="@+id/tvStandardLabel"
        android:layout_width="350dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:gravity="start"
        android:text="【標準】"
        android:textSize="18sp"
        android:textColor="#888888"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/btnSave" />
</androidx.constraintlayout.widget.ConstraintLayout>